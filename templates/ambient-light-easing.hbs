<section class="tab standard-form scrollable {{tabs.easing.cssClass}}"
    data-tab="easing" data-group="{{tabs.easing.group}}">
    <fieldset class="soft-light-ease-tab">
        <legend>{{localize "SOFTLIGHTEASE.Tabs.easing"}}</legend>

        {{#if lightEase.available}}
        <div class="form-group">
            <label>{{localize "SOFTLIGHTEASE.Fields.enabled.label"}}</label>
            <div class="form-fields checkbox-row">
                <input type="checkbox" name="flags.soft-light-ease.enabled" data-dtype="Boolean" {{checked lightEase.enabled}}>
            </div>
            <p class="hint">{{localize "SOFTLIGHTEASE.Fields.enabled.hint"}}</p>
        </div>

        <div class="form-group">
            <label>{{localize "SOFTLIGHTEASE.Fields.inner.label"}}</label>
            <div class="form-fields">
                <input type="number" name="flags.soft-light-ease.innerEase" value="{{lightEase.innerEase}}"
                    min="0" max="1" step="0.05" data-dtype="Number" inputmode="decimal">
            </div>
            <p class="hint">{{localize "SOFTLIGHTEASE.Fields.inner.hint" ease=lightEase.fallbackEase}}</p>
        </div>

        <div class="form-group">
            <label>{{localize "SOFTLIGHTEASE.Fields.outer.label"}}</label>
            <div class="form-fields">
                <input type="number" name="flags.soft-light-ease.outerEase" value="{{lightEase.outerEase}}"
                    min="0" max="1" step="0.05" data-dtype="Number" inputmode="decimal">
            </div>
            <p class="hint">{{localize "SOFTLIGHTEASE.Fields.outer.hint" ease=lightEase.fallbackEase}}</p>
        </div>

        <div class="form-group">
            <label>{{localize "SOFTLIGHTEASE.Fields.curve.label"}}</label>
            <div class="form-fields">
                <select name="flags.soft-light-ease.curve" data-dtype="String">
                    {{selectOptions lightEase.curveOptions selected=lightEase.curve localize=true}}
                </select>
            </div>
            <p class="hint">{{localize "SOFTLIGHTEASE.Fields.curve.hint"}}</p>
        </div>

        <p class="hint module-note">{{localize "SOFTLIGHTEASE.Note"}}</p>
        {{else}}
        <p class="hint unavailable-note">
            <i class="fa-solid fa-triangle-exclamation"></i>
            {{localize "SOFTLIGHTEASE.Unavailable"}}
        </p>
        {{/if}}
    </fieldset>
</section>
